{
  "expo": {
    "name": "IWAC",
    "slug": "iwac-conference",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iwacapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.wacassociation.iwac",
      "buildNumber": "4",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow access to your photos so you can choose a profile picture. This is optional."
      }
    },
    "android": {
      "icon": "./assets/images/icon-android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-android-foreground.png",
        "backgroundColor": "#f3ebdc"
      },
      "edgeToEdgeEnabled": true,
      "abiFilters": [
        "arm64-v8a",
        "x86_64",
        "arm64-v8a",
        "x86_64"
      ],
      "minSdkVersion": 26,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "org.wacassociation.iwac",
      "versionCode": 8,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos so you can choose a profile picture. This is optional."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#c4e8fc",
          "dark": {
            "backgroundColor": "#031a34"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5828739-669d-488e-b1c0-ee3f3919d2e7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a5828739-669d-488e-b1c0-ee3f3919d2e7"
    }
  }
}
