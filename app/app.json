{
  "expo": {
    "name": "IWAC",
    "slug": "iwac-conference",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iwacapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.wacassociation.iwac",
      "buildNumber": "3",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow access to your photos so you can choose a profile picture. This is optional."
      }
    },
    "android": {
      "icon": "./assets/images/icon-android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-android-foreground.png",
        "backgroundColor": "#f3ebdc"
      },
      "edgeToEdgeEnabled": true,
      "abiFilters": ["arm64-v8a", "x86_64"],
      "minSdkVersion": 26,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "org.wacassociation.iwac",
      "versionCode": 7
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos so you can choose a profile picture. This is optional."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#c4e8fc",
          "dark": {
            "backgroundColor": "#031a34"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef145f14-72b0-4176-8e77-6cb8c5978aaa"
      }
    }
  }
}
